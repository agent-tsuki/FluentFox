# docker/Dockerfile.dev
# Local development only — NEVER used in production.
# Source is mounted as a volume; air handles hot reload + rebuild.

# Separate deps layer so go mod download is only re-run when go.mod/go.sum change.
FROM golang:1.25-alpine AS deps

WORKDIR /app

RUN go install github.com/air-verse/air@latest

COPY go.mod go.sum ./
RUN go mod download

# Stage 2
FROM deps AS dev

RUN mkdir -p tmp

# Source is bind-mounted at runtime via docker-compose volume.
# Air watches .go files, rebuilds ./tmp/server, and reruns on changes.
CMD ["air", "-c", ".air.toml"]
