# docker/Dockerfile.prod
# Multi-stage production build — final image target: under 20 MB.
#
# Layer order (least → most frequently changed):
#   1. OS packages           — almost never
#   2. go mod download       — only when go.mod/go.sum change
#   3. go build              — every code change
#   4. runtime image copy    — every code change

# Stage 1: deps
FROM golang:1.23-alpine AS deps

WORKDIR /build

# Only copy dependency manifests first, cache this layer independently.
COPY go.mod go.sum ./
RUN go mod download

# Stage 2: builder
FROM deps AS builder

# Copy source after deps are cached.
COPY . .

# -s -w strips DWARF debug info and symbol table → smaller binary.
# CGO_ENABLED=0 produces a fully static binary (no glibc dependency).
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-s -w" \
    -trimpath \
    -o /out/server \
    ./cmd/api

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-s -w" \
    -trimpath \
    -o /out/sync-content \
    ./cmd/sync-content

# Stage 3: runtime
FROM alpine:3.21 AS runtime

# ca-certificates  → HTTPS outbound calls
# tzdata           → time.LoadLocation() support
RUN apk add --no-cache ca-certificates tzdata && \
    addgroup -S appgroup && \
    adduser  -S appuser -G appgroup

WORKDIR /app

# Binaries
COPY --from=builder /out/server        ./server
COPY --from=builder /out/sync-content  ./sync-content

# Migrations run on startup when RUN_MIGRATIONS=true
COPY --from=builder /build/db/migrations ./db/migrations

# Static content for sync-content binary
COPY --from=builder /build/content ./content

USER appuser

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost:8080/health || exit 1

CMD ["./server"]
